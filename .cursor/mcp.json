{
  "mcpServers": {
    "better-t-stack": {
      "command": "bunx",
      "args": ["create-better-t-stack@latest", "mcp"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "nx": {
      "command": "npx",
      "args": ["nx", "mcp", "."]
    },
    "better-auth": {
      "url": "https://mcp.inkeep.com/better-auth/mcp"
    },
    "expo-mcp": {
      "url": "https://mcp.expo.dev/mcp"
    }
  }
}
