{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"worker:image": "bun run ../../packages/api/src/workers/image-process.ts",
		"worker:trending": "bun run ../../packages/api/src/workers/trending-recalc.ts",
		"worker:all": "bun run ../../packages/api/src/workers/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@sinclair/typebox": "0.34.49",
		"@slap/api": "workspace:*",
		"@slap/auth": "workspace:*",
		"@slap/db": "workspace:*",
		"@slap/env": "workspace:*",
		"better-auth": "catalog:",
		"bullmq": "^5.79.1",
		"dotenv": "catalog:",
		"elysia": "catalog:",
		"evlog": "^2.18.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@slap/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.21.9",
		"typescript": "catalog:"
	}
}
